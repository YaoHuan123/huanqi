# Local dev: SQLite file in prisma/ (no Docker/Postgres required)
DATABASE_URL="file:./dev.db"

# Session signing
SESSION_SECRET="change-me-in-production"

# Cron job auth
CRON_SECRET="change-me-in-production"

# LLM — OpenAI-compatible (Volcengine Ark example from hello chat)
OPENAI_API_KEY=""
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_MODEL=doubao-seed-2-0-pro-260215
OPENAI_EMBEDDING_MODEL=doubao-embedding-large-text-240915

# llm = chat similarity (Volcengine default); embedding = OpenAI /embeddings API
HUANQI_SIMILARITY_MODE=llm

# Web beta: free unlock without Stripe/IAP while debugging UX
WEB_BETA_FREE_UNLOCK="true"
# Web beta: no daily publish cap (set to false to enforce 2/day like production)
WEB_BETA_UNLIMITED_SENSATIONS="true"

# Email OTP (Resend — https://resend.com)
# Email OTP: leave RESEND empty + EMAIL_OTP_DEV_MOCK=1 for local (code 123456 on login page)
RESEND_API_KEY=""
EMAIL_OTP_DEV_MOCK=1

# Apple Sign In (Apple Developer → App ID io.github.YaoHuan123.huanqi)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
# PEM private key; use \n for newlines in .env
APPLE_PRIVATE_KEY=""
# Local iOS dev without Apple keys: identityToken dev-apple-mock-token
APPLE_AUTH_DEV_MOCK=1

# Contact encryption at rest — 64 hex chars = 32 bytes (openssl rand -hex 32)
CONTACT_ENCRYPTION_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APPLE_BUNDLE_ID="io.github.YaoHuan123.huanqi"
NEXT_PUBLIC_APPLE_DEV_MOCK=1
