{
  "name": "mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "build:ios": "vite build --mode ios",
    "cap:sync": "cap sync android",
    "cap:sync:ios": "cap sync ios",
    "cap:open": "cap open android",
    "cap:open:ios": "cap open ios",
    "android": "npx cross-env CAPACITOR_PLATFORM=android npm run build:android && npx cross-env CAPACITOR_PLATFORM=android cap sync android",
    "ios": "npx cross-env CAPACITOR_PLATFORM=ios npm run build:ios && npx cross-env CAPACITOR_PLATFORM=ios cap sync ios && node scripts/patch-ios-plist.mjs && node scripts/ensure-ios-server-url.mjs"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@capacitor/status-bar": "^7.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.8.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "vite": "^6.3.5"
  }
}
