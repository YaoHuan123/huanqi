# Copy to .env.ios.local before building iOS (gitignored)
# iOS Simulator (Mac)
CAPACITOR_SERVER_URL=http://127.0.0.1:3001
VITE_APP_URL=http://127.0.0.1:3001

# Physical device on same Wi-Fi:
# CAPACITOR_SERVER_URL=http://192.168.1.222:3001
# VITE_APP_URL=http://192.168.1.222:3001

# Production:
# CAPACITOR_SERVER_URL=https://app.yourdomain.com
# VITE_APP_URL=https://app.yourdomain.com
